# ─── Exchange Rate ───────────────────────────────────────────────────────────────
# 1 USD = how many ARS (Argentine Pesos)
ARS_TO_USD=1200

# ─── Database ────────────────────────────────────────────────────────────────────
# Path to SQLite file. Railway: mount a volume and point here.
DB_PATH=./data/epicodes.db

# ─── Server ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Email Alerts (Nodemailer) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu-app-password
ALERT_EMAIL_TO=tu@gmail.com

# ─── Telegram Alerts ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=987654321

# ─── Scraper ─────────────────────────────────────────────────────────────────────
# Extra delay between requests in ms (randomised: BASE to BASE*2)
SCRAPER_DELAY_MS=1500
# Set to "true" to run Chromium in headed mode for local debugging
PLAYWRIGHT_HEADLESS=true

# ─── PlatPrices (price history & sale prediction) ─────────────────────────────
# Free key at https://platprices.com/developers.php (500 calls/hour)
# Leave blank to disable -- app works fine without it.
PLATPRICES_KEY=your_key_here
